{
	"name": "study-spark.ai",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"supa-start": "supabase start",
		"supa-stop": "supabase stop",
		"supa-restart": "supabase stop && supabase start",
		"develop": "supabase start && vercel dev",
		"push": "node commit-and-version.js",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"update-types": "npx supabase gen types typescript --project-id \"iuebreqawegqwtackphi\" --schema public > src/lib/database/types.ts && npx better-supabase-types -i ./src/lib/database/types.ts -o ./src/lib/database/types.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^2.0.0",
		"@sveltejs/kit": "^1.20.4",
		"@types/nprogress": "^0.2.0",
		"@types/uuid": "^9.0.3",
		"@typescript-eslint/eslint-plugin": "^5.45.0",
		"@typescript-eslint/parser": "^5.45.0",
		"autoprefixer": "^10.4.15",
		"daisyui": "^3.7.3",
		"eslint": "^8.28.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte": "^2.30.0",
		"postcss": "^8.4.29",
		"prettier": "^2.8.0",
		"prettier-plugin-svelte": "^2.10.1",
		"rollup-plugin-copy": "^3.5.0",
		"supabase": "^1.106.1",
		"svelte": "^4.0.5",
		"svelte-check": "^3.4.3",
		"tailwindcss": "^3.3.3",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^4.4.2"
	},
	"type": "module",
	"dependencies": {
		"@google-cloud/documentai": "^8.0.1",
		"@stdlib/nlp-sentencize": "^0.0.2",
		"@supabase/auth-helpers-sveltekit": "^0.10.1",
